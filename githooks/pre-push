#!/usr/bin/env bash
# .githooks/pre-push — main is PR-only (ADR-0023, SAD-177).
#
# git feeds "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on stdin;
# any update to refs/heads/main (including deletion) is rejected unless
# ALLOW_MAIN_PUSH=1 (Jason-only). git canonicalizes refspecs before invoking
# this hook, so every spelling (heads/main, HEAD:refs/heads/main, +main) is
# caught. Worktrees share the primary checkout's git config, so one
# `git config core.hooksPath .githooks` (tools/dev/setup-repo.sh) covers all.
#
# KNOWN LIMIT (Barb audit, PR #159): `git push --no-verify` and core.hooksPath
# overrides skip this hook entirely — a git invariant, not a bug here. The
# Claude-hook F6 rule flags those as evasion signals on agent Bash;
# main-guard.yml is the server-side backstop for everything else.

set -u

[ "${ALLOW_MAIN_PUSH:-0}" = "1" ] && exit 0

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  [ -z "${remote_ref:-}" ] && continue
  if [ "$remote_ref" = "refs/heads/main" ]; then
    {
      echo "pre-push: BLOCKED — main is PR-only (ADR-0023). Land via a PR: tools/dev/land-pr.sh <PR#> (/land)."
      echo "          ALLOW_MAIN_PUSH=1 overrides (Jason-only)."
    } >&2
    exit 1
  fi
done

exit 0
